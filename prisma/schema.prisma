generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("Manager")
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  email            String    @unique
  phone            String
  reminderConsent  Boolean   @default(true)
  marketingConsent Boolean   @default(false)
  totalSpent       Decimal   @default(0)
  totalBookings    Int       @default(0)
  lastVisitAt      DateTime?
  lastPaymentAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bookings         Booking[]
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id               String           @id @default(cuid())
  categoryId       String?
  category         ServiceCategory? @relation(fields: [categoryId], references: [id])
  name             String
  slug             String           @unique
  shortDescription String?
  description      String?
  duration         Int              @default(30)
  durationMinutes  Int?
  durationLabel    String?
  price            Decimal          @default(0)
  priceLabel       String?
  image            String?
  imageAlt         String?
  features         Json?
  isFeatured       Boolean          @default(false)
  isActive         Boolean          @default(true)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  items            BookingItem[]
  giftCardPurchases GiftCardPurchase[]
  giftCards         GiftCard[]
  giftCardPurchaseItems GiftCardPurchaseServiceItem[]
  giftCardServiceItems GiftCardServiceItem[]
}

model Technician {
  id        String    @id @default(cuid())
  name      String
  role      String
  specialty String
  rating    Decimal   @default(5)
  avatar    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Booking {
  id               String             @id @default(cuid())
  bookingCode      String             @unique
  customerId       String
  customer         Customer           @relation(fields: [customerId], references: [id])
  technicianId     String?
  technician       Technician?        @relation(fields: [technicianId], references: [id])
  status           String
  paymentStatus    String
  scheduledStartAt DateTime
  scheduledEndAt   DateTime
  subtotal         Decimal
  discountAmount   Decimal            @default(0)
  taxAmount        Decimal            @default(0)
  depositAmount    Decimal            @default(0)
  paymentMethod    String             @default("PAY_AT_SALON")
  giftCardId       String?
  giftCardReservedAmount Decimal       @default(0)
  totalAmount      Decimal
  notes            String?
  internalNotes    String?
  checkedInAt      DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  noShowAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  items            BookingItem[]
  addonItems       BookingAddonItem[]
  payments         Payment[]
  giftCard         GiftCard?          @relation(fields: [giftCardId], references: [id])
  giftCardTransactions GiftCardTransaction[]
}

model BookingItem {
  id                  String  @id @default(cuid())
  bookingId           String
  serviceId           String
  serviceNameSnapshot String?
  price               Decimal
  duration            Int
  booking             Booking @relation(fields: [bookingId], references: [id])
  service             Service @relation(fields: [serviceId], references: [id])
}

model Payment {
  id                 String    @id @default(cuid())
  bookingId          String
  amount             Decimal
  status             String
  provider           String    @default("manual")
  currency           String    @default("USD")
  purpose            String?
  providerOrderId    String?   @unique
  providerCaptureId  String?   @unique
  providerPayerId    String?
  providerPayerEmail String?
  providerPayerName  String?
  providerStatus     String?
  refundAmount       Decimal   @default(0)
  refundedAt         DateTime?
  failureCode        String?
  failureReason      String?
  providerPayload    Json?
  paidAt             DateTime?
  createdAt          DateTime  @default(now())
  booking            Booking   @relation(fields: [bookingId], references: [id])

  @@index([provider])
  @@index([providerOrderId])
  @@index([providerCaptureId])
}

model BookingAddonItem {
  id                String   @id @default(cuid())
  bookingId         String
  addonId           String?
  addonNameSnapshot String
  price             Decimal
  duration          Int      @default(0)
  createdAt         DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PaymentGatewayConfig {
  id                      String   @id @default(cuid())
  provider                String   @unique @default("paypal")
  isEnabled               Boolean  @default(false)
  environment             String   @default("sandbox")
  clientId                String?
  encryptedClientSecret   String?
  webhookId               String?
  currency                String   @default("USD")
  chargeMode              String   @default("deposit")
  depositPercentage       Decimal  @default(25)
  bookingHoldMinutes      Int      @default(15)
  autoConfirmAfterPayment Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model BookingCheckoutSession {
  id               String    @id @default(cuid())
  publicToken      String    @unique
  status           String    @default("created")
  customerPayload  Json
  bookingPayload   Json
  quoteSnapshot    Json
  technicianId     String?
  scheduledStartAt DateTime
  scheduledEndAt   DateTime
  currency         String
  totalAmount      Decimal
  paymentAmount    Decimal
  chargeMode       String
  paypalOrderId    String?   @unique
  paypalCaptureId  String?   @unique
  paypalPayerId    String?
  paypalPayerEmail String?
  paypalPayerName  String?
  bookingId        String?   @unique
  expiresAt        DateTime
  completedAt      DateTime?
  failedAt         DateTime?
  cancelledAt      DateTime?
  idempotencyKey   String?   @unique
  failureCode      String?
  failureReason    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([technicianId, scheduledStartAt, scheduledEndAt])
  @@index([expiresAt])
}

model PaymentWebhookEvent {
  id                 String    @id @default(cuid())
  provider           String
  providerEventId    String    @unique
  eventType          String
  verificationStatus String
  processingStatus   String    @default("received")
  providerOrderId    String?
  providerCaptureId  String?
  checkoutSessionId  String?
  payload            Json
  processingError    String?
  processedAt        DateTime?
  createdAt          DateTime  @default(now())

  @@index([provider])
  @@index([eventType])
  @@index([providerOrderId])
  @@index([providerCaptureId])
}

enum GiftCardType {
  AMOUNT
  SERVICE
}

enum GiftCardStatus {
  PENDING_PAYMENT
  PAID
  ISSUED
  PARTIALLY_REDEEMED
  REDEEMED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum GiftCardTransactionType {
  ISSUE
  REDEEM
  ADJUSTMENT
  VOID
  REFUND
  EXPIRE
  RESERVATION
  RELEASE_RESERVATION
}

enum GiftCardEmailStatus {
  PENDING
  SENT
  FAILED
}

enum TransactionalEmailKind {
  BOOKING_REQUEST_RECEIVED
  BOOKING_CONFIRMED
  BOOKING_RESCHEDULED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  GIFT_CARD_DELIVERY
  GIFT_CARD_PURCHASE_RECEIPT
  GIFT_CARD_RESEND
  SMTP_TEST
}

enum TransactionalEmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model GiftCardPurchase {
  id                      String          @id @default(cuid())
  orderNumber             String          @unique
  type                    GiftCardType
  amount                  Decimal
  currency                String          @default("USD")
  purchaserName           String
  purchaserEmail          String
  recipientName           String
  recipientEmail          String
  senderName              String
  senderEmail             String
  message                 String
  serviceId               String?
  service                 Service?        @relation(fields: [serviceId], references: [id])
  serviceNameSnapshot     String?
  servicePriceSnapshot    Decimal?
  serviceDurationSnapshot Int?
  serviceSubtotal         Decimal         @default(0)
  gratuityAmount          Decimal         @default(0)
  totalAmount             Decimal         @default(0)
  paypalOrderId           String?         @unique
  paypalCaptureId         String?         @unique
  paypalStatus            String?
  status                  GiftCardStatus  @default(PENDING_PAYMENT)
  createdAt               DateTime        @default(now())
  paidAt                  DateTime?
  updatedAt               DateTime        @updatedAt
  giftCard                GiftCard?
  items                   GiftCardPurchaseServiceItem[]

  @@index([status])
  @@index([recipientEmail])
  @@index([purchaserEmail])
  @@index([createdAt])
  @@index([serviceId])
}

model GiftCardPurchaseServiceItem {
  id                      String           @id @default(cuid())
  purchaseId              String
  purchase                GiftCardPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  serviceId               String?
  service                 Service?         @relation(fields: [serviceId], references: [id])
  serviceNameSnapshot     String
  servicePriceSnapshot    Decimal
  serviceDurationSnapshot Int
  sortOrder               Int              @default(0)
  createdAt               DateTime         @default(now())

  @@index([purchaseId])
  @@index([serviceId])
}

model GiftCard {
  id                      String              @id @default(cuid())
  purchaseId              String              @unique
  purchase                GiftCardPurchase    @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  type                    GiftCardType
  codeHash                String              @unique
  codeCiphertext          String
  codeSuffix              String
  initialAmount           Decimal
  remainingBalance        Decimal
  currency                String              @default("USD")
  serviceId               String?
  service                 Service?            @relation(fields: [serviceId], references: [id])
  serviceNameSnapshot     String?
  servicePriceSnapshot    Decimal?
  serviceDurationSnapshot Int?
  gratuityAmount          Decimal             @default(0)
  gratuityRedeemedAt      DateTime?
  recipientName           String
  recipientEmail          String
  senderName              String
  senderEmail             String
  message                 String
  status                  GiftCardStatus      @default(ISSUED)
  issuedAt                DateTime?
  expiresAt               DateTime?
  sentAt                  DateTime?
  emailStatus             GiftCardEmailStatus @default(PENDING)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  transactions            GiftCardTransaction[]
  serviceItems            GiftCardServiceItem[]
  bookings                Booking[]

  @@index([status])
  @@index([recipientEmail])
  @@index([senderEmail])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([serviceId])
}

model GiftCardServiceItem {
  id                      String   @id @default(cuid())
  giftCardId              String
  giftCard                GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  serviceId               String?
  service                 Service? @relation(fields: [serviceId], references: [id])
  serviceNameSnapshot     String
  servicePriceSnapshot    Decimal
  serviceDurationSnapshot Int
  sortOrder               Int      @default(0)
  redeemedAt              DateTime?
  redeemedBookingId       String?
  createdAt               DateTime @default(now())

  @@index([giftCardId])
  @@index([serviceId])
  @@index([redeemedAt])
}

model GiftCardTransaction {
  id                String                  @id @default(cuid())
  giftCardId        String
  giftCard          GiftCard                @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  type              GiftCardTransactionType
  amount            Decimal
  bookingId         String?
  booking           Booking?                @relation(fields: [bookingId], references: [id])
  performedByUserId String?
  note              String?
  createdAt         DateTime                @default(now())

  @@index([giftCardId])
  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
}

model GiftCardSetting {
  id                 String   @id @default(cuid())
  key                String   @unique @default("default")
  currency           String   @default("USD")
  amountPresetValues Json
  minCustomAmount    Int      @default(25)
  maxCustomAmount    Int      @default(500)
  allowCustomAmount  Boolean  @default(true)
  expirationEnabled  Boolean  @default(false)
  giftCardsEnabled   Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GiftCardTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  palette     Json?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Promotion {
  id               String    @id @default(cuid())
  code             String    @unique
  title            String
  description      String?
  amount           Decimal
  type             String
  active           Boolean   @default(true)
  firstBookingOnly Boolean   @default(false)
  validUntil       DateTime?
  bannerImage      String?
  termsHtml        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  sku          String   @unique
  category     String
  unit         String
  currentStock Int
  reorderLevel Int
  supplier     String?
  costPerUnit  Decimal
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements InventoryMovement[]
}

model Review {
  id        String   @id @default(cuid())
  customer  String
  rating    Int
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GalleryItem {
  id          String           @id @default(cuid())
  categoryId  String?
  category    GalleryCategory? @relation(fields: [categoryId], references: [id])
  title       String
  slug        String           @unique
  description String?
  image       String
  imageAlt    String?
  tag         String?
  isHighlight Boolean          @default(false)
  isActive    Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actor       String
  action      String
  entity      String
  entityType  String?
  entityId    String?
  performedBy String?
  details     Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
}

model SitePageContent {
  id               String    @id @default(cuid())
  slug             String    @unique
  draftContent     Json
  publishedContent Json?
  version          Int       @default(1)
  updatedBy        String?
  publishedBy      String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([slug])
}

model NavigationMenu {
  id             String    @id @default(cuid())
  key            String    @unique
  name           String
  description    String?
  location       String    @unique
  draftItems     Json
  publishedItems Json?
  version        Int       @default(1)
  updatedBy      String?
  publishedBy    String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([location])
}

model NavigationMenuSetting {
  id                  String   @id @default(cuid())
  key                 String   @unique
  headerMobileMode    String   @default("inherit_header_primary")
  headerMobileMenuKey String?
  footerLayout        String   @default("four_columns")
  footerShowSocial    Boolean  @default(true)
  footerShowLegal     Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ServiceAddon {
  id          String   @id @default(cuid())
  name        String
  price       Decimal?
  priceLabel  String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServicePackage {
  id         String   @id @default(cuid())
  name       String
  subtitle   String?
  price      Decimal?
  priceLabel String?
  badge      String?
  features   Json?
  isPopular  Boolean  @default(false)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ServiceFaq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceGalleryItem {
  id        String   @id @default(cuid())
  title     String?
  image     String
  imageAlt  String?
  tag       String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServicesPageSetting {
  id                   String   @id @default(cuid())
  heroEyebrow          String?
  heroTitle            String?
  heroHighlight        String?
  heroDescription      String?
  heroImage            String?
  heroImageAlt         String?
  primaryButtonLabel   String?
  primaryButtonHref    String?
  secondaryButtonLabel String?
  secondaryButtonHref  String?
  whyChooseTitle       String?
  whyChooseDescription String?
  whyChooseImage       String?
  ctaTitle             String?
  ctaDescription       String?
  ctaButtonLabel       String?
  ctaButtonHref        String?
  phone                String?
  email                String?
  address              String?
  hours                String?
  seoTitle             String?
  seoDescription       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model GalleryPageSetting {
  id                   String   @id @default(cuid())
  seoTitle             String?
  seoDescription       String?
  heroEyebrow          String?
  heroTitle            String?
  heroHighlight        String?
  heroDescription      String?
  heroImage            String?
  heroImageAlt         String?
  primaryButtonLabel   String?
  primaryButtonHref    String?
  secondaryButtonLabel String?
  secondaryButtonHref  String?
  whyEyebrow           String?
  whyTitle             String?
  whyDescription       String?
  whyImage             String?
  whyImageAlt          String?
  ctaTitle             String?
  ctaDescription       String?
  ctaButtonLabel       String?
  ctaButtonHref        String?
  phone                String?
  email                String?
  address              String?
  hours                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model GalleryCategory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  items       GalleryItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GalleryCollection {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  image       String
  imageAlt    String?
  designCount Int      @default(0)
  sortOrder   Int      @default(0)
  isFeatured  Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryTrend {
  id        String   @id @default(cuid())
  title     String
  image     String?
  imageAlt  String?
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryProcessStep {
  id          String   @id @default(cuid())
  step        String
  icon        String?
  title       String
  description String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryTestimonial {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  avatarAlt String?
  rating    Int      @default(5)
  quote     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PackagePageSetting {
  id                   String   @id @default(cuid())
  seoTitle             String?
  seoDescription       String?
  heroEyebrow          String?
  heroTitle            String?
  heroHighlight        String?
  heroDescription      String?
  heroImage            String?
  heroImageAlt         String?
  primaryButtonLabel   String?
  primaryButtonHref    String?
  secondaryButtonLabel String?
  secondaryButtonHref  String?
  benefitsEyebrow      String?
  benefitsTitle        String?
  benefitsDescription  String?
  benefitsImage        String?
  benefitsImageAlt     String?
  benefitsButtonLabel  String?
  benefitsButtonHref   String?
  comparisonTitle      String?
  rewardsTitle         String?
  occasionsTitle       String?
  processTitle         String?
  testimonialsTitle    String?
  faqTitle             String?
  ctaTitle             String?
  ctaDescription       String?
  ctaButtonLabel       String?
  ctaButtonHref        String?
  phone                String?
  email                String?
  address              String?
  hours                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PackageCategory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  packages    NailPackage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model NailPackage {
  id               String           @id @default(cuid())
  categoryId       String?
  category         PackageCategory? @relation(fields: [categoryId], references: [id])
  name             String
  slug             String           @unique
  subtitle         String?
  shortDescription String?
  description      String?
  image            String?
  imageAlt         String?
  price            Decimal?
  priceLabel       String?
  durationLabel    String?
  visitCountLabel  String?
  badge            String?
  features         Json?
  isPopular        Boolean          @default(false)
  isFeatured       Boolean          @default(true)
  isActive         Boolean          @default(true)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model PackageBenefit {
  id          String   @id @default(cuid())
  icon        String?
  title       String
  description String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PackageComparisonFeature {
  id             String   @id @default(cuid())
  featureName    String
  essentialValue String?
  signatureValue String?
  premiumValue   String?
  vipValue       String?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PackageReward {
  id          String   @id @default(cuid())
  icon        String?
  title       String
  description String
  image       String?
  imageAlt    String?
  promoTitle  String?
  promoValue  String?
  buttonLabel String?
  buttonHref  String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PackageOccasion {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  imageAlt    String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PackageProcessStep {
  id          String   @id @default(cuid())
  step        String
  icon        String?
  title       String
  description String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageTestimonial {
  id        String   @id @default(cuid())
  pageKey   String
  name      String
  role      String?
  avatar    String?
  avatarAlt String?
  rating    Int      @default(5)
  quote     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageKey])
}

model PageFaq {
  id        String   @id @default(cuid())
  pageKey   String
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageKey])
}

model PageContentBlock {
  id         String   @id @default(cuid())
  pageKey    String
  sectionKey String
  blockKey   String
  label      String?
  value      String?
  jsonValue  Json?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pageKey])
  @@index([sectionKey])
}

model BlogPageSetting {
  id String @id @default(cuid())

  seoTitle       String?
  seoDescription String?

  heroEyebrow          String?
  heroTitle            String?
  heroHighlight        String?
  heroDescription      String?
  heroImage            String?
  heroImageAlt         String?
  primaryButtonLabel   String?
  primaryButtonHref    String?
  secondaryButtonLabel String?
  secondaryButtonHref  String?

  latestTitle       String?
  browseTitle       String?
  editorsPickTitle  String?
  testimonialsTitle String?

  sidebarCategoriesTitle String?
  sidebarTrendingTitle   String?
  newsletterTitle        String?
  newsletterDescription  String?
  newsletterPlaceholder  String?
  newsletterButtonLabel  String?

  ctaTitle       String?
  ctaDescription String?
  ctaButtonLabel String?
  ctaButtonHref  String?
  phone          String?
  email          String?
  address        String?
  hours          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  imageAlt    String?
  icon        String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum BlogPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id         String        @id @default(cuid())
  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])

  title       String
  slug        String  @unique
  excerpt     String?
  content     String?
  contentJson Json?

  coverImage    String?
  coverImageAlt String?
  coverMediaId  String?

  authorName   String?
  authorAvatar String?
  authorRole   String?

  readTimeMinutes Int?
  status          BlogPostStatus @default(DRAFT)

  isFeatured    Boolean @default(false)
  isTrending    Boolean @default(false)
  isEditorsPick Boolean @default(false)
  isPinned      Boolean @default(false)

  publishedAt DateTime?
  scheduledAt DateTime?

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  faqs     Json?
  products Json?

  aiGenerated       Boolean @default(false)
  aiContentJobId    String? @unique
  aiImagePrompt     String?
  generatedLanguage String?
  generationVersion String?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiProviderSetting {
  id                    String    @id @default(cuid())
  provider              String    @unique @default("openai")
  isEnabled             Boolean   @default(false)
  encryptedApiKey       String?
  apiKeyLastFour        String?
  apiKeyConfiguredAt    DateTime?
  textModel             String    @default("gpt-5.4-mini")
  imageModel            String    @default("gpt-image-2")
  defaultOutputLanguage String    @default("en")
  defaultArticleTone    String    @default("luxury_editorial")
  defaultArticleLength  Int       @default(1200)
  defaultGenerateImage  Boolean   @default(true)
  defaultImageSize      String    @default("1536x1024")
  defaultImageQuality   String    @default("medium")
  maxKeywordsPerBatch   Int       @default(30)
  maxConcurrentJobs     Int       @default(1)
  maxRetriesPerJob      Int       @default(2)
  monthlyBudgetLimit    Decimal?
  monthlyBudgetUsed     Decimal   @default(0)
  humanReviewRequired   Boolean   @default(true)
  autoScheduleEnabled   Boolean   @default(true)
  lastTestStatus        String?
  lastTestedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model AiContentBatch {
  id                    String         @id @default(cuid())
  name                  String?
  rawKeywordInput       String
  normalizedKeywords    Json
  outputLanguage        String         @default("en")
  categoryId            String?
  status                String         @default("queued")
  generationMode        String         @default("draft")
  scheduleStartAt       DateTime?
  scheduleIntervalHours Int?
  timezone              String?
  generateImages        Boolean        @default(true)
  textModel             String
  imageModel            String?
  requestedBy           String?
  completedAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  jobs                  AiContentJob[]

  @@index([status])
  @@index([createdAt])
}

model EmailSmtpSetting {
  id                    String   @id @default(cuid())
  key                   String   @unique @default("default")
  enabled               Boolean  @default(false)
  host                  String?
  port                  Int?
  secure                Boolean  @default(false)
  smtpEncryptionMode    String   @default("STARTTLS")
  username              String?
  encryptedPassword     String?
  fromName              String?
  fromEmail             String?
  replyToEmail          String?
  verifiedAt            DateTime?
  lastVerificationError String?
  lastTestSentAt        DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TransactionalEmailLog {
  id            String                   @id @default(cuid())
  kind          TransactionalEmailKind
  status        TransactionalEmailStatus @default(PENDING)
  recipient     String
  subject       String
  entityType    String?
  entityId      String?
  attempts      Int                      @default(0)
  lastError     String?
  lastAttemptAt DateTime?
  sentAt        DateTime?
  nextRetryAt   DateTime?
  metadata      Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([status, nextRetryAt])
  @@index([entityType, entityId])
  @@index([recipient])
  @@index([createdAt])
}

model AiContentJob {
  id                  String              @id @default(cuid())
  batchId             String
  batch               AiContentBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  keyword             String
  normalizedKeyword   String
  sortOrder           Int
  categoryId          String?
  status              String              @default("queued")
  attemptCount        Int                 @default(0)
  maxAttempts         Int                 @default(2)
  scheduledPublishAt  DateTime?
  lockedAt            DateTime?
  lockedBy            String?
  startedAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  textModel           String
  imageModel          String?
  generateImage       Boolean             @default(true)
  requestSnapshot     Json?
  articleSnapshot     Json?
  imagePrompt         String?
  imageGenerationMeta Json?
  blogPostId          String?             @unique
  coverMediaId        String?
  providerResponseId  String?
  inputTokens         Int?
  outputTokens        Int?
  imageCount          Int                 @default(0)
  estimatedCost       Decimal?
  errorCode           String?
  errorMessage        String?
  retryAfter          DateTime?
  idempotencyKey      String              @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  events              AiContentJobEvent[]

  @@unique([batchId, normalizedKeyword])
  @@index([status, scheduledPublishAt])
  @@index([keyword])
  @@index([blogPostId])
}

model AiContentJobEvent {
  id        String       @id @default(cuid())
  jobId     String
  eventType String
  message   String?
  metadata  Json?
  createdAt DateTime     @default(now())
  job       AiContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model MediaFolder {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets MediaAsset[]

  @@index([parentId])
}

model MediaAsset {
  id               String    @id @default(cuid())
  fileName         String
  originalName     String?
  url              String
  mimeType         String?
  originalMimeType String?
  size             Int?
  width            Int?
  height           Int?
  alt              String?
  title            String?
  folder           String?
  storageKey       String?
  provider         String?   @default("local")
  folderId         String?
  uploadedBy       String?
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  mediaFolder MediaFolder? @relation(fields: [folderId], references: [id])
  usages      MediaUsage[]

  @@index([folderId])
  @@index([isDeleted])
}

model MediaUsage {
  id         String   @id @default(cuid())
  mediaId    String
  entityType String
  entityId   String
  fieldKey   String
  createdAt  DateTime @default(now())

  media MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entityType, entityId, fieldKey])
  @@index([mediaId])
  @@index([entityType, entityId])
}

model InventoryMovement {
  id              String   @id @default(cuid())
  inventoryItemId String
  type            String // "adjustment", "purchase", "usage", "return"
  quantity        Int
  previousStock   Int
  newStock        Int
  reason          String?
  performedBy     String?
  createdAt       DateTime @default(now())

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
}

